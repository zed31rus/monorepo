{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "composite": true,
    "paths": {
      "@zed31rus/types": ["../types/index.ts"],
      "@shared/errors": ["../shared/errors/index.ts"],
      "@shared/config": ["../shared/config/index.ts"],
      "@shared/logger": ["../shared/logger/index.ts"]
    }
  },
  "include": ["./**/*", "./*"],
  "references": [
    { "path": "../types" },
    { "path": "../shared/errors" },
    { "path": "../shared/config" },
    { "path": "../shared/logger" }
  ]
}