{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "composite": true,
    "paths": {
      "@zed31rus/types": ["../../types/index.ts"],
      "@shared/errors": ["../../shared/errors/index.ts"],
      "@shared/config": ["../../shared/config/index.ts"],
      "@shared/logger": ["../../shared/logger/index.ts"],
      "@zed31rus/base": ["../../base/index.ts"],
      "@packages/libs": ["../../packages/libs/index.ts"],
      "@packages/db": ["../../packages/db/index.ts"],
      "@packages/infra": ["../../packages/infra/index.ts"],

      "#root/*": ["./*"],
      "#core/*": ["./core/*"],
      "#web/*": ["./web/*"]
    }
  },
  "include": [
    "./**/*"
  ],
  "references": [
    { "path": "../../types" },
    { "path": "../../shared/errors" },
    { "path": "../../shared/config" },
    { "path": "../../shared/logger"},
    { "path": "../../base" },
    { "path": "../../packages/libs" },
    { "path": "../../packages/db" },
    { "path": "../../packages/infra" }
  ]
}